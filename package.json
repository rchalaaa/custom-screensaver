{
  "name": "org.rchalaaa.webos.custom-screensaver",
  "version": "1.0.1",
  "main": "frontend/index.js",
  "moduleDir": "frontend",
  "scripts": {
    "build": "node tools/build.js",
    "package": "ares-package dist/",
    "manifest": "tools/gen-manifest.js ${npm_package_name}.manifest.json",
    "deploy": "ares-install ${npm_package_name}_${npm_package_version}_all.ipk",
    "launch": "ares-launch ${npm_package_name}",
    "version": "node tools/sync-version.js && git add appinfo.json",
    "clean": "rm -rf dist/"
  },
  "assets": [
    "appinfo.json",
    "assets/**/*.*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rchalaaa/custom-screensaver"
  },
  "styles": [
    "frontend/styles.css"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@webosose/ares-cli": "^2.2.0"
  },
  "dependencies": {}
}
